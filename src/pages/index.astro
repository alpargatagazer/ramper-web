---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  {/* Asymmetric hand art grid - matching the Figma layout */}
  <div class="flex flex-col justify-center items-center h-full p-12 gap-8" id="index-grid">
    {/* Top row: large hand-1 (fist) + medium hand-2 (drooping) */}
    <div class="flex gap-12 items-start translate-x-[-40px]">
      <img 
        src="/images/hands/hand-1.svg" 
        alt="Hand illustration — fist" 
        class="w-[360px] h-auto object-contain"
      />
      <img 
        src="/images/hands/hand-2.svg" 
        alt="Hand illustration — drooping hand" 
        class="w-[320px] h-auto object-contain mt-12"
      />
    </div>
    {/* Bottom row: large hand-3 (bird/flying) + small hand-4 (thumbs) */}
    <div class="flex gap-16 items-start translate-x-[40px]">
      <img 
        src="/images/hands/hand-3.svg" 
        alt="Hand illustration — flying hand" 
        class="w-[380px] h-auto object-contain"
      />
      <img 
        src="/images/hands/hand-4.svg" 
        alt="Hand illustration — pointing hand" 
        class="w-[220px] h-auto object-contain mt-8"
      />
    </div>
  </div>
</BaseLayout>

