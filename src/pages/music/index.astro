---
// src/pages/music/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const releases = await getCollection('releases');
// Sort chronologically for mobile fallback
releases.sort((a, b) => new Date(b.data.releaseDate).valueOf() - new Date(a.data.releaseDate).valueOf());

// Map precise desktop layout sizes and positions
const layoutStyles: Record<string, string> = {
  '1-el-hoyo': 'md:absolute md:w-[180px] md:left-[80px] md:top-[0px]',
  '2-nuestros-mejores-deseos': 'md:absolute md:w-[300px] md:left-[300px] md:top-[-60px]',
  '3-sesiones-bravas': 'md:absolute md:w-[180px] md:left-[650px] md:top-[80px]',
  '4-solo-postres': 'md:absolute md:w-[300px] md:left-[50px] md:top-[300px]',
  '5-el-tamborilero': 'md:absolute md:w-[140px] md:left-[390px] md:top-[310px]',
  '6-la-caja-del-diablo': 'md:absolute md:w-[140px] md:left-[440px] md:top-[530px]',
  '7-solo-postres-en-teatros-del-canal': 'md:absolute md:w-[250px] md:left-[630px] md:top-[340px]'
};

// Display label for non-album types
const typeLabels: Record<string, string> = {
  single: 'Single',
  ep: 'EP',
  live: 'Directo',
  demo: 'Demo en directo',
  session: 'Sesión en directo',
};
---

<BaseLayout title="Ramper — música" activeSection="music">
  <div class="h-full overflow-y-auto overflow-x-hidden p-8 pt-[180px] max-w-[1000px] mx-auto" id="music-grid">
    
    <div class="flex flex-col gap-16 items-center md:block md:relative md:w-full md:min-h-[720px]">
      {releases.map((release) => {
        const coverSrc = release.data.coverImage 
          ? `/images/covers/${release.data.coverImage}` 
          : null;
        const year = new Date(release.data.releaseDate).getFullYear();
        const typeLabel = typeLabels[release.data.type];
        const desktopStyles = layoutStyles[release.id] || 'md:relative md:w-[200px]';
        
        return (
          <a 
            href={`/music/${release.id}`} 
            class:list={[
              'block group transition-transform duration-300 hover:scale-[1.02] hover:z-50 relative z-10',
              'w-[80%] max-w-[400px]', // Mobile default width
              desktopStyles
            ]}
            id={`release-${release.id}`}
          >
            {coverSrc ? (
              <img 
                src={coverSrc} 
                alt={`Portada de ${release.data.title}`}
                class="w-full h-auto object-cover aspect-square noise-overlay shadow-sm"
              />
            ) : (
              <div class="w-full aspect-square bg-ramper-black/10 flex items-center justify-center text-xs text-ramper-black/40 uppercase tracking-widest shadow-sm">
                Cover
              </div>
            )}
            <div class="text-center mt-2 w-full">
              <p class="font-bold text-ramper-black text-[13px] leading-tight">
                {release.data.title} ({year})
              </p>
              {typeLabel && (
                <p class="text-[11px] text-ramper-black/60 mt-1">
                  [{typeLabel}]
                </p>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
