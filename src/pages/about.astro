---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const aboutData = await getCollection('about');
const aboutEntry = aboutData.length > 0 ? aboutData[0] : null;

// Render Markdoc to HTML using modern Astro 5 helper
const { Content } = aboutEntry ? await render(aboutEntry) : { Content: null };
---

<BaseLayout title="About | Ramper">
  <div class="mb-16">
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-8">About</h1>
  </div>

  <div class="prose dark:prose-invert max-w-3xl prose-p:text-ramper-blue-deep dark:prose-p:text-ramper-white/80 prose-headings:text-ramper-black dark:prose-headings:text-ramper-white prose-a:text-ramper-blue-mid dark:prose-a:text-ramper-blue-light hover:prose-a:text-ramper-blue-deep dark:hover:prose-a:text-ramper-white transition-colors">
    {Content ? <Content /> : <p>Biography content is missing. Please add it via Keystatic.</p>}
  </div>
</BaseLayout>
