---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const aboutEntry = await getEntry('about', 'index');
const { Content } = aboutEntry ? await render(aboutEntry) : { Content: null };
---

<BaseLayout title="Ramper | ¿...quién?" activeSection="about">
  <div class="flex flex-col h-full overflow-y-auto" id="about-content">
    {/* Band photo — occupies most of the right content area top */}
    <div class="flex-shrink-0">
      <img 
        src="/images/band.png" 
        alt="Ramper - foto de banda" 
        class="w-full h-auto object-cover"
        id="band-photo"
      />
    </div>

    {/* Bio text — below the photo */}
    <div class="px-8 py-6 max-w-4xl" id="about-bio">
      <div class="text-xl leading-tight tracking-tight text-ramper-black">
        {Content && <Content />}
      </div>
    </div>
  </div>
</BaseLayout>
