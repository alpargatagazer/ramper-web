---
// src/pages/news/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Ramper`}>
  <article class="max-w-3xl mx-auto">
    
    <header class="mb-12 border-b border-ramper-blue-mid/20 dark:border-ramper-white/10 pb-12 text-center">
      <time datetime={post.data.date} class="text-sm font-mono text-ramper-blue-mid/80 dark:text-ramper-blue-light/80 mb-4 block tracking-widest uppercase">
        {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6">{post.data.title}</h1>
      <p class="text-xl text-ramper-blue-mid dark:text-ramper-blue-light font-medium">{post.data.summary}</p>
    </header>

    <div class="prose dark:prose-invert max-w-none prose-p:text-ramper-blue-deep dark:prose-p:text-ramper-white/80 prose-headings:text-ramper-black dark:prose-headings:text-ramper-white prose-a:text-ramper-blue-mid dark:prose-a:text-ramper-blue-light hover:prose-a:text-ramper-blue-deep dark:hover:prose-a:text-ramper-white prose-img:border prose-img:border-ramper-blue-mid/20 dark:prose-img:border-ramper-white/10 shadow-sm dark:shadow-none transition-colors">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-ramper-blue-mid/20 dark:border-ramper-white/10">
      <a href="/news" class="text-sm uppercase tracking-widest font-bold text-ramper-blue-mid dark:text-ramper-blue-light hover:text-ramper-blue-deep dark:hover:text-ramper-white transition-colors">
        ← Back to all news
      </a>
    </footer>

  </article>
</BaseLayout>
