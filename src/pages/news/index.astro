---
// src/pages/news/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
// Newest first
posts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<BaseLayout title="Ramper | noticias" activeSection="news">
  <div class="page-container pt-section-top">
    
    <div class="p- md:p-12">
      {/* RSS link - aligned with content column */}
      <div class="flex justify-end mb-2">
        <a 
          href="/rss.xml" 
          target="_blank" 
          class="flex items-center gap-1 link-secondary text-ramper-black hover:text-ramper-blue-deep"
          id="rss-link"
        >
          <span>RSS</span>
          <img src="/icons/rss.png" alt="" class="w-2.5 h-2.5" />
        </a>
      </div>

      {/* News list - individual boxes */}
      <div class="space-y-8">
        {posts.length === 0 ? (
          <p class="text-ramper-black/50 italic">No hay noticias publicadas todavía.</p>
        ) : (
          posts.map((post) => (
            <article class="group content-overlay p-8 md:p-6 transition-transform hover:scale-[1.01]">
              <a href={`/news/${post.id}`} class="block hover:opacity-80 transition-opacity">
                <time 
                  datetime={post.data.date} 
                  class="text-sm text-ramper-blue-deep mb-1 block"
                >
                  {new Date(post.data.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h2 class="section-title !mb-2 group-hover:text-ramper-blue-deep transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-ramper-black/70 leading-relaxed max-w-2xl">
                  {post.data.summary}
                </p>
              </a>
            </article>
          ))
        )}
      </div>
    </div>
  </div>
</BaseLayout>
