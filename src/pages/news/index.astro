---
// src/pages/news/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
posts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<BaseLayout title="News | Ramper">
  <div class="mb-16 flex justify-between items-end border-b border-ramper-blue-mid/20 dark:border-ramper-white/10 pb-8">
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">News</h1>
    <a href="/rss.xml" target="_blank" class="text-xs uppercase tracking-widest font-bold text-ramper-blue-mid dark:text-ramper-blue-light hover:text-ramper-blue-deep dark:hover:text-ramper-white transition-colors flex items-center gap-2">
      RSS Feed
    </a>
  </div>

  <div class="space-y-12">
    {posts.length === 0 ? (
      <p class="text-ramper-blue-mid/70 dark:text-ramper-blue-light/70 italic">No news published yet.</p>
    ) : (
      posts.map((post) => (
        <article class="group">
          <a href={`/news/${post.id}`} class="block border-l-2 border-transparent hover:border-ramper-blue-mid dark:hover:border-ramper-blue-light pl-6 transition-colors">
            <time datetime={post.data.date} class="text-sm font-mono text-ramper-blue-mid/80 dark:text-ramper-blue-light/80 mb-2 block">
              {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="text-2xl font-bold mb-3 group-hover:text-ramper-blue-mid dark:group-hover:text-ramper-blue-light transition-colors">{post.data.title}</h2>
            <p class="text-ramper-blue-mid dark:text-ramper-blue-light leading-relaxed max-w-3xl">
              {post.data.summary}
            </p>
          </a>
        </article>
      ))
    )}
  </div>
</BaseLayout>
